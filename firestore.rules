// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: logs
// Document ID: {logId}
// Fields:
//   - id: string (required) - Unique log ID
//   - timestamp: timestamp (required) - Time of verification
//   - nationalId: string (required) - National ID of the user
//   - fullName: string (required) - Full name of the user
//   - status: string (required, enum: ['APPROVED', 'REJECTED']) - Result of verification
//   - confidence: number (required) - AI confidence score
//   - userData: map (required) - Full user data at time of verification
//   - photoUrl: string (optional) - URL to the selfie photo
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User email
//   - role: string (required, enum: ['admin', 'user']) - User role
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "altajm41@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidLog(data) {
      return data.keys().hasAll(['id', 'timestamp', 'nationalId', 'fullName', 'status', 'confidence', 'userData']) &&
             data.id is string &&
             data.timestamp is timestamp &&
             data.nationalId is string &&
             data.fullName is string &&
             data.status in ['APPROVED', 'REJECTED'] &&
             data.confidence is number &&
             data.userData is map;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /logs/{logId} {
      // Users can create their own logs during verification
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
      
      // Only admins can read all logs or search
      allow read: if isAdmin();
      
      // Logs are immutable
      allow update, delete: if false;
    }

    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId) || isAdmin();
      
      // Only admins can create or update user roles
      // Exception: A user can create their own profile as 'user' if it doesn't exist
      allow create: if isAuthenticated() && 
                      isValidUser(request.resource.data) && 
                      ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
                      
      allow update: if isAdmin() && isValidUser(request.resource.data);
      
      allow delete: if isAdmin();
    }
  }
}
